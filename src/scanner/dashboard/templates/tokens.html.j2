{% extends "base.html.j2" %}

{% set active_page = "tokens" %}

{% block title %}API Tokens{% endblock %}

{% block extra_styles %}
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.page-header h1 {
  font-size: 20px;
  font-weight: 600;
  line-height: 1.2;
}

.token-form {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 24px;
  margin-bottom: 24px;
}

.token-form h2 {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 16px;
}

.token-form .form-row {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.token-form .form-group {
  flex: 1;
  min-width: 180px;
}

.token-form label {
  display: block;
  font-size: 12px;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 4px;
}

.token-form .form-actions {
  display: flex;
  gap: 8px;
  align-items: center;
  margin-top: 16px;
}

.token-form .form-actions .discard-link {
  text-decoration: none;
  color: var(--color-text-secondary);
  font-size: 14px;
}

.token-form .form-actions .discard-link:hover {
  color: var(--color-text);
}
{% endblock %}

{% block content %}
<div class="page-header">
  <h1>API Tokens</h1>
  {% if active_count >= token_limit %}
  <button class="btn btn--accent" disabled title="Maximum of 10 active tokens reached. Revoke an existing token first." style="opacity: 0.5; cursor: not-allowed;">Generate Token</button>
  {% else %}
  <button class="btn btn--accent" onclick="document.getElementById('token-form').style.display = document.getElementById('token-form').style.display === 'none' ? 'block' : 'none'">Generate Token</button>
  {% endif %}
</div>

{% if new_token %}
<div class="success-alert">
  Token created successfully. Copy it now -- you will not see it again.
</div>
<div class="token-value" style="margin-bottom: 24px;">
  {{ new_token }}
</div>
{% endif %}

<div id="token-form" class="token-form" style="display: none;">
  <h2>Generate Token</h2>
  <form method="POST" action="/dashboard/tokens">
    <div class="form-row">
      <div class="form-group">
        <label for="token-name">Name</label>
        <input type="text" id="token-name" name="name" class="form-input" placeholder="e.g. CI/CD Pipeline" required>
      </div>
      <div class="form-group">
        <label for="token-expires">Expiration</label>
        <select id="token-expires" name="expires" class="form-select">
          <option value="never" selected>Never</option>
          <option value="30">30 days</option>
          <option value="90">90 days</option>
          <option value="365">1 year</option>
        </select>
      </div>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn--accent">Generate Token</button>
      <a href="#" class="discard-link" onclick="document.getElementById('token-form').style.display='none'; return false;">Discard</a>
    </div>
  </form>
</div>

{% if tokens %}
<table>
  <thead>
    <tr>
      <th>Name</th>
      <th style="width: 200px;">Token</th>
      <th style="width: 140px;">Created</th>
      <th style="width: 140px;">Expires</th>
      <th style="width: 140px;">Last Used</th>
      <th style="width: 80px;">Actions</th>
    </tr>
  </thead>
  <tbody>
    {% for t in tokens %}
    <tr>
      <td>{{ t.name }}</td>
      <td><span class="token-masked">nvsec_{{ t.token_hash[:8] }}...</span></td>
      <td>{{ t.created_at.strftime('%Y-%m-%d') if t.created_at else '-' }}</td>
      <td>{{ t.expires_at.strftime('%Y-%m-%d') if t.expires_at else 'Never' }}</td>
      <td>{{ t.last_used_at.strftime('%Y-%m-%d') if t.last_used_at else 'Never' }}</td>
      <td>
        {% if t.revoked_at is none %}
        <form method="POST" action="/dashboard/tokens/{{ t.id }}/revoke" style="display: inline;">
          <button type="submit" class="btn btn--small btn--destructive" onclick="return confirm('Revoke token {{ t.name }}? This cannot be undone. Any CI/CD pipelines using this token will stop working.')">Revoke</button>
        </form>
        {% else %}
        <span style="color: var(--color-text-secondary); font-size: 12px;">Revoked</span>
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<div class="empty-state">
  <h2>No API tokens</h2>
  <p>Generate a token to authenticate API requests from CI/CD pipelines.</p>
</div>
{% endif %}
{% endblock %}
