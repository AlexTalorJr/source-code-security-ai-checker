<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Security Scan Report</title>
</head>
<body style="margin:0; padding:0; background-color:#f8f9fa; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#f8f9fa;">
    <tr>
      <td align="center" style="padding:24px 0;">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px; background-color:#ffffff; border-radius:8px; overflow:hidden;">

          <!-- Header bar -->
          <tr>
            <td style="background-color:#0d6efd; height:48px; padding:0 24px;">
              <span style="color:#ffffff; font-size:14px; font-weight:bold; line-height:48px;">aipix-security-scanner</span>
            </td>
          </tr>

          <!-- Gate banner -->
          {% if gate_passed %}
          <tr>
            <td style="background-color:#d4edda; padding:24px; text-align:center;">
              <span style="font-size:28px; font-weight:600; color:#155724;">Quality Gate: PASSED</span>
            </td>
          </tr>
          {% else %}
          <tr>
            <td style="background-color:#f8d7da; padding:24px; text-align:center;">
              <span style="font-size:28px; font-weight:600; color:#721c24;">Quality Gate: FAILED</span>
            </td>
          </tr>
          {% endif %}

          <!-- Target info -->
          <tr>
            <td style="padding:16px 24px 4px 24px;">
              <span style="font-size:14px; font-weight:600; color:#212529;">Scan #{{ scan_result.id }}</span>
              <div style="font-size:13px; color:#495057; margin-top:4px; word-break:break-all;">
                {{ scan_result.repo_url or scan_result.target_path or 'unknown' }}
              </div>
            </td>
          </tr>

          <!-- Metadata row -->
          <tr>
            <td style="padding:4px 24px 8px 24px;">
              <span style="font-size:12px; color:#6c757d;">
                Branch: {{ scan_result.branch or 'local' }}
                {% if scan_result.commit_hash %} &middot; Commit: {{ scan_result.commit_hash[:8] }}{% endif %}
                {% if scan_result.duration_seconds is not none %} &middot; Duration: {{ scan_result.duration_seconds | round(0) | int }}s{% endif %}
              </span>
            </td>
          </tr>

          <!-- Severity table -->
          <tr>
            <td style="padding:8px 24px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="border-collapse:collapse;">
                <tr style="background-color:#e9ecef;">
                  <td style="padding:8px 12px; font-size:12px; font-weight:bold; color:#495057;">Severity</td>
                  <td style="padding:8px 12px; font-size:12px; font-weight:bold; color:#495057; text-align:right;">Count</td>
                  <td style="padding:8px 12px; font-size:12px; font-weight:bold; color:#495057; width:50%;"></td>
                </tr>
                <tr style="background-color:#ffffff;">
                  <td style="padding:8px 12px; font-size:13px; color:#dc3545; font-weight:600;">Critical</td>
                  <td style="padding:8px 12px; font-size:13px; text-align:right;">{{ scan_result.critical_count }}</td>
                  <td style="padding:8px 12px;">
                    {% if scan_result.critical_count > 0 %}
                    <div style="background-color:#dc3545; height:8px; border-radius:4px; width:{{ [scan_result.critical_count * 10, 100] | min }}%;"></div>
                    {% endif %}
                  </td>
                </tr>
                <tr style="background-color:#f8f9fa;">
                  <td style="padding:8px 12px; font-size:13px; color:#fd7e14; font-weight:600;">High</td>
                  <td style="padding:8px 12px; font-size:13px; text-align:right;">{{ scan_result.high_count }}</td>
                  <td style="padding:8px 12px;">
                    {% if scan_result.high_count > 0 %}
                    <div style="background-color:#fd7e14; height:8px; border-radius:4px; width:{{ [scan_result.high_count * 10, 100] | min }}%;"></div>
                    {% endif %}
                  </td>
                </tr>
                <tr style="background-color:#ffffff;">
                  <td style="padding:8px 12px; font-size:13px; color:#ffc107; font-weight:600;">Medium</td>
                  <td style="padding:8px 12px; font-size:13px; text-align:right;">{{ scan_result.medium_count }}</td>
                  <td style="padding:8px 12px;">
                    {% if scan_result.medium_count > 0 %}
                    <div style="background-color:#ffc107; height:8px; border-radius:4px; width:{{ [scan_result.medium_count * 10, 100] | min }}%;"></div>
                    {% endif %}
                  </td>
                </tr>
                <tr style="background-color:#f8f9fa;">
                  <td style="padding:8px 12px; font-size:13px; color:#28a745; font-weight:600;">Low</td>
                  <td style="padding:8px 12px; font-size:13px; text-align:right;">{{ scan_result.low_count }}</td>
                  <td style="padding:8px 12px;">
                    {% if scan_result.low_count > 0 %}
                    <div style="background-color:#28a745; height:8px; border-radius:4px; width:{{ [scan_result.low_count * 10, 100] | min }}%;"></div>
                    {% endif %}
                  </td>
                </tr>
                <tr style="background-color:#ffffff;">
                  <td style="padding:8px 12px; font-size:13px; color:#6c757d; font-weight:600;">Info</td>
                  <td style="padding:8px 12px; font-size:13px; text-align:right;">{{ scan_result.info_count }}</td>
                  <td style="padding:8px 12px;">
                    {% if scan_result.info_count > 0 %}
                    <div style="background-color:#6c757d; height:8px; border-radius:4px; width:{{ [scan_result.info_count * 10, 100] | min }}%;"></div>
                    {% endif %}
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Delta section -->
          {% if delta is not none %}
          <tr>
            <td style="padding:8px 24px 16px 24px;">
              <span style="font-size:12px; font-weight:bold; color:#495057;">Delta from previous scan:</span>
              <span style="display:inline-block; margin-left:8px; padding:2px 8px; border-radius:10px; background-color:#f8d7da; color:#dc3545; font-size:12px; font-weight:600;">+{{ delta.new_fingerprints | length }} new</span>
              <span style="display:inline-block; margin-left:4px; padding:2px 8px; border-radius:10px; background-color:#d4edda; color:#28a745; font-size:12px; font-weight:600;">-{{ delta.fixed_fingerprints | length }} fixed</span>
            </td>
          </tr>
          {% endif %}

          <!-- CTA button -->
          <tr>
            <td style="padding:16px 24px; text-align:center;">
              <a href="{{ dashboard_url }}/scans/{{ scan_result.id }}" style="display:inline-block; padding:12px 32px; background-color:#0d6efd; color:#ffffff; text-decoration:none; border-radius:6px; font-size:14px; font-weight:600;">View Full Report</a>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:16px 24px; border-top:1px solid #e9ecef;">
              <span style="font-size:12px; color:#6c757d;">Sent by aipix-security-scanner. Configure notifications in config.yml.</span>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
