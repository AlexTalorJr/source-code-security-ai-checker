# aipix-security-scanner environment variables
# Copy to .env and fill in real values

# Required
SCANNER_API_KEY=your-api-key-here
SCANNER_CLAUDE_API_KEY=your-claude-api-key-here

# Server
SCANNER_PORT=8000
SCANNER_DB_PATH=/data/scanner.db
SCANNER_CONFIG_PATH=config.yml

# Git (for private repo scanning)
SCANNER_GIT_TOKEN=

# Notifications - Slack
SCANNER_SLACK_WEBHOOK_URL=

# Notifications - Email
SCANNER_EMAIL_SMTP_HOST=
SCANNER_NOTIFICATIONS__EMAIL__SMTP_PORT=587
SCANNER_NOTIFICATIONS__EMAIL__SMTP_USER=
SCANNER_NOTIFICATIONS__EMAIL__SMTP_PASSWORD=
SCANNER_NOTIFICATIONS__EMAIL__RECIPIENTS=[]
