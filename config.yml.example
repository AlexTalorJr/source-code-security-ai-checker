# aipix-security-scanner configuration
# Copy to config.yml and customize. Secrets should use env vars instead.
host: "0.0.0.0"
port: 8000
db_path: "/data/scanner.db"
api_key: ""  # Set via SCANNER_API_KEY env var
claude_api_key: ""  # Set via SCANNER_CLAUDE_API_KEY env var
slack_webhook_url: ""
email_smtp_host: ""
log_level: "info"
scan_timeout: 600

scanners:
  semgrep:
    enabled: true
    timeout: 180
    extra_args: []
  cppcheck:
    enabled: true
    timeout: 120
    extra_args: []
  gitleaks:
    enabled: true
    timeout: 120
    extra_args: []
  trivy:
    enabled: true
    timeout: 120
    extra_args: []
  checkov:
    enabled: true
    timeout: 120
    extra_args: []
