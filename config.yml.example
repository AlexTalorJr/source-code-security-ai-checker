# Security AI Scanner configuration
# Copy to config.yml and customize. Secrets should use env vars instead.
host: "0.0.0.0"
port: 8000
db_path: "/data/scanner.db"
api_key: ""  # Set via SCANNER_API_KEY env var
claude_api_key: ""  # Set via SCANNER_CLAUDE_API_KEY env var
slack_webhook_url: ""
email_smtp_host: ""
log_level: "info"
scan_timeout: 600

# Scanners: enabled can be true, false, or "auto" (default)
# "auto" enables scanners based on detected languages in the target project
scanners:
  semgrep:
    enabled: auto  # Python, PHP, JS/TS, Go, Java, Ruby, C#, Rust
    timeout: 180
    extra_args: ["--exclude", ".venv", "--exclude", "node_modules"]
  cppcheck:
    enabled: auto  # C/C++ projects
    timeout: 120
    extra_args: ["-i.venv", "-inode_modules"]
  gitleaks:
    enabled: auto  # Always runs (secrets in any language)
    timeout: 120
    extra_args: []
  trivy:
    enabled: auto  # Docker, Terraform, Kubernetes
    timeout: 120
    extra_args: []
  checkov:
    enabled: auto  # Docker, Terraform, CI configs
    timeout: 120
    extra_args: ["--skip-path", ".venv", "--skip-path", "node_modules"]
  psalm:
    enabled: auto  # PHP projects (taint analysis for SQL injection, XSS)
    timeout: 300
    extra_args: []
  enlightn:
    enabled: auto  # Laravel projects (CSRF, mass assignment, debug mode)
    timeout: 120
    extra_args: []
  php_security_checker:
    enabled: auto  # PHP projects with composer.lock (CVE detection)
    timeout: 30
    extra_args: []
  nuclei:
    enabled: true  # DAST scanner (not language-dependent, runs when target_url provided)
    timeout: 300
    extra_args: []
    adapter_class: "scanner.adapters.nuclei.NucleiAdapter"
    languages: []

ai:
  max_cost_per_scan: 5.0
  model: "claude-sonnet-4-6"
  max_findings_per_batch: 50
  max_tokens_per_response: 4096

# Quality gate
gate:
  fail_on:
    - critical
    - high
  include_compound_risks: true

# Notifications
notifications:
  slack:
    enabled: false
  email:
    enabled: false
    recipients: []
    smtp_port: 587
    smtp_user: ""
    smtp_password: ""  # Set via SCANNER_NOTIFICATIONS__EMAIL__SMTP_PASSWORD env var
    use_tls: true

# Dashboard
dashboard_url: ""  # e.g., http://scanner:8000/dashboard (auto-derived if empty)
