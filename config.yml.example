# Security AI Scanner configuration
# Copy to config.yml and customize. Secrets should use env vars instead.
host: "0.0.0.0"
port: 8000
db_path: "/data/scanner.db"
api_key: ""  # Set via SCANNER_API_KEY env var
claude_api_key: ""  # Set via SCANNER_CLAUDE_API_KEY env var
slack_webhook_url: ""
email_smtp_host: ""
log_level: "info"
scan_timeout: 600

scanners:
  semgrep:
    enabled: true
    timeout: 180
    extra_args: []
  cppcheck:
    enabled: true
    timeout: 120
    extra_args: []
  gitleaks:
    enabled: true
    timeout: 120
    extra_args: []
  trivy:
    enabled: true
    timeout: 120
    extra_args: []
  checkov:
    enabled: true
    timeout: 120
    extra_args: []

ai:
  max_cost_per_scan: 5.0
  model: "claude-sonnet-4-6"
  max_findings_per_batch: 50
  max_tokens_per_response: 4096

# Quality gate
gate:
  fail_on:
    - critical
    - high
  include_compound_risks: true

# Notifications
notifications:
  slack:
    enabled: false
  email:
    enabled: false
    recipients: []
    smtp_port: 587
    smtp_user: ""
    smtp_password: ""  # Set via SCANNER_NOTIFICATIONS__EMAIL__SMTP_PASSWORD env var
    use_tls: true

# Dashboard
dashboard_url: ""  # e.g., http://scanner:8000/dashboard (auto-derived if empty)
